// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// User schema for Google OAuth integration (Auth.js v5)
model User {
  id            String      @id @default(uuid())
  email         String      @unique
  name          String?
  emailVerified DateTime?   @map("email_verified")
  image         String?
  createdAt     DateTime    @default(now()) @map("created_at")
  links         ShortLink[]
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model ShortLink {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  longUrl     String    @map("long_url")
  creatorId   String?   @map("creator_id") // Optional until Phase 4 (auth)
  creator     User?     @relation(fields: [creatorId], references: [id])
  
  // Phase 2 scheduling columns
  validFrom   DateTime? @map("valid_from")
  validUntil  DateTime? @map("valid_until")
  maxClicks   Int?      @map("max_clicks")
  fallbackUrl String?   @map("fallback_url")
  bypassAuth  Boolean   @default(true) @map("bypass_auth")
  
  createdAt   DateTime  @default(now()) @map("created_at")

  analyticsEvents  AnalyticsEvent[]
  hourlyAggregates HourlyAggregate[]

  @@map("short_links")
}

model AnalyticsEvent {
  id        Int       @id @default(autoincrement())
  linkId    Int       @map("link_id")
  link      ShortLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  isUnique  Boolean   @map("is_unique")
  userAgent String?   @map("user_agent")
  country   String?
  city      String?
  clickedAt DateTime  @default(now()) @map("clicked_at")

  @@index([linkId, clickedAt])
  @@map("analytics_events")
}

model HourlyAggregate {
  id           Int       @id @default(autoincrement())
  linkId       Int       @map("link_id")
  link         ShortLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  timeBucket   DateTime  @map("time_bucket")
  clicks       Int       @default(0)
  uniqueClicks Int       @default(0) @map("unique_clicks")

  @@unique([linkId, timeBucket])
  @@map("hourly_aggregates")
}
