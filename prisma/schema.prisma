// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// User schema added in Phase 4 for Google login integrations
model User {
  id        String      @id @default(uuid())
  email     String      @unique
  name      String?
  createdAt DateTime    @default(now()) @map("created_at")
  links     ShortLink[]

  @@map("users")
}

model ShortLink {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  longUrl     String    @map("long_url")
  creatorId   String?   @map("creator_id") // Optional until Phase 4 (auth)
  creator     User?     @relation(fields: [creatorId], references: [id])
  
  // Phase 2 scheduling columns
  validFrom   DateTime? @map("valid_from")
  validUntil  DateTime? @map("valid_until")
  maxClicks   Int?      @map("max_clicks")
  fallbackUrl String?   @map("fallback_url")
  bypassAuth  Boolean   @default(true) @map("bypass_auth")
  
  createdAt   DateTime  @default(now()) @map("created_at")

  analyticsEvents  AnalyticsEvent[]
  hourlyAggregates HourlyAggregate[]

  @@map("short_links")
}

model AnalyticsEvent {
  id        Int       @id @default(autoincrement())
  linkId    Int       @map("link_id")
  link      ShortLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  isUnique  Boolean   @map("is_unique")
  userAgent String?   @map("user_agent")
  country   String?
  city      String?
  clickedAt DateTime  @default(now()) @map("clicked_at")

  @@index([linkId, clickedAt])
  @@map("analytics_events")
}

model HourlyAggregate {
  id           Int       @id @default(autoincrement())
  linkId       Int       @map("link_id")
  link         ShortLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  timeBucket   DateTime  @map("time_bucket")
  clicks       Int       @default(0)
  uniqueClicks Int       @default(0) @map("unique_clicks")

  @@unique([linkId, timeBucket])
  @@map("hourly_aggregates")
}
